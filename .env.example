# .env.example — Local development with local PostgreSQL
# Copy to .env and use with: docker compose up --build
# (No changes needed — all defaults work out of the box)

# Database — automatically set to local postgres container
# NEON_JDBC_URL=jdbc:postgresql://db:5432/portfolio  ← handled by docker-compose.yml
# NEON_USERNAME=postgres
# NEON_PASSWORD=postgres

# JWT — dev secret (do NOT use in production)
JWT_SECRET=localDevSecretKeyThatIsAtLeast256BitsLongForHS512Algorithm123456789

# Email (optional — leave empty to disable contact form emails)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
