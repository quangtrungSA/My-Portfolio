# .env.prod.example — Production (Oracle Cloud VM + Neon database)
# Copy to .env.prod on the Oracle Cloud VM — NEVER commit this file
# Usage: docker compose -f docker-compose.prod.yml up --build -d

# ── Database (Neon) ───────────────────────────────────────────────────────────
NEON_JDBC_URL=jdbc:postgresql://<neon-host>.neon.tech:5432/<db-name>?sslmode=require
NEON_USERNAME=<neon-username>
NEON_PASSWORD=<neon-password>

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=<generate-a-64+-char-random-string-here>

# ── Email (optional) ─────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-gmail>@gmail.com
# Use Gmail App Password (not account password): https://myaccount.google.com/apppasswords
MAIL_PASSWORD=<gmail-app-password>

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=<your-email>@gmail.com
